# ============================================================
# Application
# ============================================================
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-64-char-string
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================================
# Database (PostgreSQL + pgvector)
# ============================================================
DATABASE_URL=postgresql+asyncpg://autonomocx:autonomocx_dev@localhost:5432/autonomocx
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DATABASE_URL_SYNC=postgresql://autonomocx:autonomocx_dev@localhost:5432/autonomocx

# ============================================================
# Redis
# ============================================================
REDIS_URL=redis://localhost:6379/0

# ============================================================
# JWT Authentication
# ============================================================
JWT_SECRET_KEY=change-me-to-a-random-64-char-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================
# AI / LLM Providers
# ============================================================
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o
FALLBACK_LLM_PROVIDER=anthropic
FALLBACK_LLM_MODEL=claude-sonnet-4-20250514
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ============================================================
# RAG Configuration
# ============================================================
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.7
RAG_RERANKING_ENABLED=false

# ============================================================
# Guardrails & Risk
# ============================================================
RISK_SCORE_APPROVAL_THRESHOLD=0.7
HALLUCINATION_CHECK_ENABLED=true
PII_DETECTION_ENABLED=true
MAX_TOOL_RETRIES=2

# ============================================================
# Channel: WhatsApp
# ============================================================
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# ============================================================
# Channel: Voice (Twilio)
# ============================================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ============================================================
# Channel: Email
# ============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ============================================================
# Storage (S3)
# ============================================================
S3_BUCKET=autonomocx-documents
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ============================================================
# Observability
# ============================================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================================
# Frontend (Vite)
# ============================================================
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_WS_URL=ws://localhost:8000/api/v1/chat/ws
VITE_APP_NAME=AutonoCX
